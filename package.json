{
  "name": "smep-afe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:local": "vite build --mode localhost",
    "build:dev": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "build": "vite build --mode development",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json}\"",
    "lint:fix": "eslint src --fix",
    "sonar": "sonar-scanner -Dsonar.host.url=https://sonarqube.smes-tipa.go.kr -Dsonar.login=$SONAR_TOKEN -Dsonar.projectKey=smep-afe -Dsonar.exclusions=**/*.test.jsx,**/*.spec.jsx,**/node_modules/**,**/dist/**,**/publishing/**"
  },
